# Production ortamı için bu dosyayı .env olarak kopyalayın ve değerleri doldurun.
# ASLA bu dosyayı gerçek değerlerle doldurmayın — bu dosya git'e eklenebilir.

# Veritabanı (SQLite için sunucu üzerindeki tam yol)
DATABASE_URL="file:/var/www/bto/data/prod.db"

# NextAuth — openssl rand -hex 32 komutu ile üretin
NEXTAUTH_SECRET="BURAYA_GUCLU_BIR_SECRET_YAZIN"

# Production domain adresiniz (https ile)
NEXTAUTH_URL="https://SITENIZIN-DOMAIN-ADI.com"
