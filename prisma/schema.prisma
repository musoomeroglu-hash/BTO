generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── KULLANICI & YETKİ ────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  username     String    @unique
  passwordHash String
  role         String    @default("VIEWER")
  active       Boolean   @default(true)
  komisyonId   String?
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  komisyon     Komisyon?       @relation("KomisyonYoneticiler", fields: [komisyonId], references: [id])
  haberler     Haber[]
  medyaListesi Medya[]
}

// ─── HABERLER ─────────────────────────────────────────────────────

model Haber {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String?
  content     String
  category    String    @default("HABER")
  imageUrl    String?
  featured    Boolean   @default(false)
  published   Boolean   @default(false)
  publishedAt DateTime?
  viewCount   Int       @default(0)
  authorId    String
  komisyonId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  author      User      @relation(fields: [authorId], references: [id])
  komisyon    Komisyon? @relation(fields: [komisyonId], references: [id])
}

// ─── ETKİNLİKLER ─────────────────────────────────────────────────

model Etkinlik {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  content     String?
  location    String   @default("Bursa")
  startDate   DateTime
  endDate     DateTime
  imageUrl    String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── DUYURULAR ────────────────────────────────────────────────────

model Duyuru {
  id        String    @id @default(cuid())
  title     String
  content   String?
  url       String?
  priority  Int       @default(0)
  active    Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
}

// ─── KOMİSYONLAR ─────────────────────────────────────────────────

model Komisyon {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  content     String?
  chairName   String?
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  yoneticiler User[]   @relation("KomisyonYoneticiler")
  haberler    Haber[]
}

// ─── YÖNETİM KURULU ──────────────────────────────────────────────

model YonetimKurulu {
  id        String  @id @default(cuid())
  name      String
  title     String
  position  String
  photoUrl  String?
  order     Int     @default(0)
  startYear Int
  endYear   Int?
  active    Boolean @default(true)
}

// ─── UNUTAMADIKLARIMIZ ────────────────────────────────────────────

model Unutamadigi {
  id            String   @id @default(cuid())
  name          String
  title         String?
  birthYear     Int?
  deathYear     Int?
  birthPlace    String?
  specialty     String?
  medicalSchool String?
  photoUrl      String?
  bio           String?
  createdAt     DateTime @default(now())
}

// ─── YAYINLAR ────────────────────────────────────────────────────

model Yayin {
  id          String   @id @default(cuid())
  title       String
  type        String   @default("DERGI")
  description String?
  content     String?
  fileUrl     String?
  coverUrl    String?
  issueNumber Int?
  publishedAt DateTime
  createdAt   DateTime @default(now())
}

// ─── MEVZUAT ─────────────────────────────────────────────────────

model Mevzuat {
  id          String   @id @default(cuid())
  title       String
  category    String
  content     String?
  fileUrl     String?
  publishedAt DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── HAFTALIK QUIZ ────────────────────────────────────────────────

model Quiz {
  id            String   @id @default(cuid())
  question      String
  imageUrl      String?
  imageCaption  String?
  options       String
  correctOption Int
  explanation   String
  weekDate      DateTime
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
}

// ─── E-BÜLTEN ABONELERİ ──────────────────────────────────────────

model BultenAbone {
  id        String   @id @default(cuid())
  email     String   @unique
  confirmed Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── İLETİŞİM MESAJLARI ──────────────────────────────────────────

model IletisimMesaji {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── MEDYA KÜTÜPHANESİ ───────────────────────────────────────────

model Medya {
  id           String   @id @default(cuid())
  filename     String
  url          String
  mimeType     String
  size         Int
  uploadedById String
  createdAt    DateTime @default(now())

  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
}

// ─── SÜREKLİ TIP EĞİTİMİ (STE) PORTALI ─────────────────────────

model SteKategori {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  iconEmoji   String?
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  kurulUyeleri SteKurulUyesi[]
  materyaller  SteMateryal[]
}

model SteKurulUyesi {
  id          String   @id @default(cuid())
  name        String
  title       String?
  institution String?
  photoUrl    String?
  order       Int      @default(0)
  kategoriId  String
  createdAt   DateTime @default(now())

  kategori    SteKategori @relation(fields: [kategoriId], references: [id], onDelete: Cascade)
}

model SteMateryal {
  id          String   @id @default(cuid())
  title       String
  type        String   @default("KITAP")
  author      String?
  description String?
  coverUrl    String?
  fileUrl     String?
  publishedAt DateTime?
  kategoriId  String
  createdAt   DateTime @default(now())

  kategori    SteKategori @relation(fields: [kategoriId], references: [id], onDelete: Cascade)
}

// ─── SİTE AYARLARI ───────────────────────────────────────────────

model SiteAyar {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
